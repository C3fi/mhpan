#!/usr/bin/env bash

# niri-move-window-to-column
# Moves the focused window to the adjacent column (left or right).
# Usage: niri-move-window-to-column.sh left|right
# now don't used at project
set -euo pipefail

DIRECTION="${1:-}"

if [[ "$DIRECTION" != "left" && "$DIRECTION" != "right" ]]; then
    echo "Usage: $0 left|right" >&2
    exit 1
fi

# 1. Get the ID of the currently focused window
FOCUSED_WINDOW_JSON=$(niri msg --json focused-window)
WINDOW_ID=$(echo "$FOCUSED_WINDOW_JSON" | jq -r '.id')

if [[ -z "$WINDOW_ID" || "$WINDOW_ID" == "null" ]]; then
    echo "No focused window found." >&2
    exit 1
fi

# 2. Get the current column ID of that window
COLUMN_ID=$(echo "$FOCUSED_WINDOW_JSON" | jq -r '.column_id')

if [[ -z "$COLUMN_ID" || "$COLUMN_ID" == "null" ]]; then
    echo "Focused window is not in a column (maybe it's floating?)." >&2
    exit 1
fi

# 3. Move the focus to the adjacent column in the desired direction
if [[ "$DIRECTION" == "left" ]]; then
    niri msg action focus-column-left
else
    niri msg action focus-column-right
fi

# 4. Get the ID of the newly focused column
NEW_COLUMN_JSON=$(niri msg --json focused-window)
NEW_COLUMN_ID=$(echo "$NEW_COLUMN_JSON" | jq -r '.column_id')

if [[ -z "$NEW_COLUMN_ID" || "$NEW_COLUMN_ID" == "null" ]]; then
    echo "Failed to focus adjacent column." >&2
    exit 1
fi

# 5. If the column ID hasn't changed (e.g., at the edge), do nothing
if [[ "$COLUMN_ID" == "$NEW_COLUMN_ID" ]]; then
    echo "Already at the edge; no column to move to." >&2
    exit 0
fi

# 6. Move the original window to the new column
niri msg action move-window-to-column --id "$WINDOW_ID" "$NEW_COLUMN_ID"

# 7. (Optional) Focus the window we just moved
niri msg action focus-window --id "$WINDOW_ID"